generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum BookingStatus {
  PENDING
  APPROVED
  REJECTED
  CANCELLED
  PAID
}

enum PaymentStatus {
  UNPAID
  DEPOSIT_PAID
  FULL_PAID
  REFUNDED
}

enum PaymentType {
  DEPOSIT
  FULL
}

model Car {
  id           String        @id @default(cuid())
  slug         String        @unique
  name         String
  brand        String
  model        String
  year         Int
  dailyPrice   Int
  description  String
  thumbnailUrl String
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
  images       CarImage[]
  bookings     Booking[]
  blockedDates BlockedDate[]
}

model CarImage {
  id        String   @id @default(cuid())
  carId     String
  url       String
  sortOrder Int      @default(0)
  createdAt DateTime @default(now())
  car       Car      @relation(fields: [carId], references: [id], onDelete: Cascade)

  @@index([carId])
}

model Booking {
  id                    String        @id @default(cuid())
  carId                  String
  stripeSessionId        String?       @unique
  stripePaymentIntentId  String?
  status                 BookingStatus @default(PENDING)
  paymentStatus          PaymentStatus @default(UNPAID)
  paymentType            PaymentType
  totalAmountCents       Int
  depositAmountCents     Int
  chargedAmountCents     Int
  startDate              DateTime
  endDate                DateTime
  pickupTime             String
  returnTime             String
  firstName              String
  lastName               String
  email                  String
  phone                  String
  licenseUrl             String
  agreementAccepted      Boolean
  notes                  String?
  createdAt              DateTime      @default(now())
  updatedAt              DateTime      @updatedAt
  car                    Car           @relation(fields: [carId], references: [id], onDelete: Cascade)

  @@index([carId])
  @@index([startDate, endDate])
  @@index([status])
}

model BlockedDate {
  id        String   @id @default(cuid())
  carId     String
  startDate DateTime
  endDate   DateTime
  reason    String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  car       Car      @relation(fields: [carId], references: [id], onDelete: Cascade)

  @@index([carId, startDate, endDate])
}
